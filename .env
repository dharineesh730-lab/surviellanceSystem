# ─────────────────────────────────────────────────────────
# Action Recognition — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Telegram Bot credentials (for fight-detection alerts)
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="8733395965:AAFXf1RCK8dzQHsd2CBnPHAzqCHN0Wg3GwU"

# Chat IDs to send alerts to — comma-separated, supports multiple recipients:
#   Positive number = private person  (e.g. 712345678)
#   Negative number = group chat      (e.g. -5140879081)
#
# Example — send to both a person AND a group:
#   TELEGRAM_CHAT_IDS=712345678,-5140879081
#
# Old single-ID format still works too (TELEGRAM_CHAT_ID)
TELEGRAM_CHAT_IDS="-5069145890"

# Alert format: "gif" (looping animation, no codec issues) or "video" (H.264 mp4)
ALERT_FORMAT=gif
